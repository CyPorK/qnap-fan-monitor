#!/bin/bash
# qnap-monitor вҖ” live dashboard: temperatures, fans, CPU load
# QNAP TVS-h1288X + Proxmox VE
# Usage: ./qnap-monitor [interval_in_seconds]
#        ./qnap-monitor --analyze <file.csv>

# в”Җв”Җ Colors в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
R='\033[0;31m' Y='\033[0;33m' G='\033[0;32m'
C='\033[0;36m' W='\033[1;37m' D='\033[2;37m' N='\033[0m'
BOLD='\033[1m' REV='\033[7m' BLINK='\033[5m'

VERSION="@VERSION@"

# в”Җв”Җ Logging / stress state в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
LOG_ACTIVE=0; LOG_FILE=""; STRESS_PID=0; STRESS_ERROR=""
command -v stress-ng &>/dev/null && HAS_STRESS_NG=1 || HAS_STRESS_NG=0
PHASE="IDLE"; COOLDOWN_START=0

# в”Җв”Җ Fancontrol parsed values в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
declare -A FC_MAXTEMP FC_MINTEMP FC_MINPWM FC_MAXPWM FC_TEMPS

# в”Җв”Җ CPU stat arrays (global вҖ” cannot declare inside functions) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
declare -A snap_total snap_idle prev_total prev_idle

# в”Җв”Җ Core detection arrays (global) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
declare -a CORE_IDS=()
declare -A CORE_TEMP=()  # core_id -> path to temp file
declare -A CORE_CPUS=()  # core_id -> "cpu0 cpu6" (thread list, space-separated)

# в”Җв”Җ Functions в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

# Auto-detect hwmon by name (resilient to numbering changes after reboot/kernel update)
find_hwmon() {
    local target="$1"
    for h in /sys/class/hwmon/hwmon*/; do
        [[ "$(cat "$h/name" 2>/dev/null)" == "$target" ]] && printf '%s' "${h%/}" && return 0
    done
    return 1
}

# bar <value> <max> <width>
bar() {
    local val=$1 max=$2 width=${3:-20}
    [ "$max" -le 0 ] && max=1
    local pct=$(( val * 100 / max ))
    [ "$pct" -gt 100 ] && pct=100
    local filled=$(( pct * width / 100 ))
    local empty=$(( width - filled ))
    local color i
    if   [ "$pct" -ge 90 ]; then color=$R
    elif [ "$pct" -ge 70 ]; then color=$Y
    else                         color=$G
    fi
    printf "${color}["
    for (( i=0; i<filled; i++ )); do printf 'в–Ҳ'; done
    for (( i=0; i<empty;  i++ )); do printf 'в–‘'; done
    printf "] %3d%%${N}" "$pct"
}

temp_color() {
    local t=$1 warn=${2:-70} crit=${3:-85}
    if   [ "$t" -ge "$crit" ]; then printf '%s' "$R"
    elif [ "$t" -ge "$warn" ]; then printf '%s' "$Y"
    else                            printf '%s' "$G"
    fi
}

read_temp() { awk '{printf "%d", $1/1000}' "$1" 2>/dev/null || echo 0; }

# Parse CPU list from thread_siblings_list (e.g. "0,6" or "0-3,8-11")
# Prints each CPU on a separate line
expand_cpu_list() {
    local result=()
    IFS=',' read -ra parts <<< "$1"
    for part in "${parts[@]}"; do
        if [[ "$part" =~ ^([0-9]+)-([0-9]+)$ ]]; then
            for (( n=${BASH_REMATCH[1]}; n<=${BASH_REMATCH[2]}; n++ )); do
                result+=("$n")
            done
        else
            result+=("$part")
        fi
    done
    printf '%s\n' "${result[@]}"
}

read_cpu_stats() {
    while read -r label user nice sys idle iowait irq softirq steal _; do
        [[ "$label" =~ ^cpu ]] || continue
        snap_total[$label]=$(( user + nice + sys + idle + iowait + irq + softirq + steal ))
        snap_idle[$label]=$(( idle + iowait ))
    done < /proc/stat
}

save_cpu_stats() {
    for k in "${!snap_total[@]}"; do
        prev_total[$k]=${snap_total[$k]}
        prev_idle[$k]=${snap_idle[$k]}
    done
}

cpu_pct() {
    local label=$1
    local dt=$(( snap_total[$label] - ${prev_total[$label]:-0} ))
    local di=$(( snap_idle[$label]  - ${prev_idle[$label]:-0}  ))
    [ "$dt" -le 0 ] && echo 0 && return
    local pct=$(( 100 * (dt - di) / dt ))
    [ "$pct" -lt 0 ]   && pct=0
    [ "$pct" -gt 100 ] && pct=100
    echo "$pct"
}

# Draw a single PWM curve row: label mintemp maxtemp minpwm maxpwm curtemp curpwm_raw
draw_pwm_curve() {
    local label="$1" mintemp="$2" maxtemp="$3" minpwm="$4" maxpwm="$5" curtemp="$6" curpwm_raw="$7"
    local width=28
    local cur_pct=$(( curpwm_raw * 100 / 255 ))

    local pos
    if   [[ "$curtemp" -le "$mintemp" ]]; then pos=0
    elif [[ "$curtemp" -ge "$maxtemp" ]]; then pos=$width
    else pos=$(( (curtemp - mintemp) * width / (maxtemp - mintemp) )); fi

    local col; [[ "$cur_pct" -ge 80 ]] && col="$R" || { [[ "$cur_pct" -ge 50 ]] && col="$Y" || col="$G"; }

    printf "  %-18s ${D}%2dВ°C [${N}" "$label" "$mintemp"
    local i
    for (( i=0; i<=width; i++ )); do
        if   [[ "$i" -lt  "$pos" ]]; then printf "${col}в•җ${N}"
        elif [[ "$i" -eq  "$pos" ]]; then printf "${W}${BOLD}в—Ҹ${N}"
        else printf "${D}в”Җ${N}"; fi
    done
    printf "${D}] %2dВ°C${N}  %3dВ°C вҶ’ ${col}PWM %3d%%${N}\n" "$maxtemp" "$curtemp" "$cur_pct"
}

# Parse /etc/fancontrol (or ./fancontrol) into FC_* associative arrays.
# Key = PWM channel name without path prefix (e.g. pwm1, pwm7).
parse_fancontrol() {
    local cfg=""
    [[ -f /etc/fancontrol ]] && cfg=/etc/fancontrol
    [[ -z "$cfg" && -f ./fancontrol ]] && cfg=./fancontrol
    [[ -z "$cfg" ]] && return 1
    while IFS= read -r line; do
        line="${line%%#*}"; [[ -z "${line// }" ]] && continue
        local varname="${line%%=*}" pairs="${line#*=}"
        case "$varname" in MAXTEMP|MINTEMP|MINPWM|MAXPWM|FCTEMPS)
            for pair in $pairs; do
                local pk="${pair%=*}"; pk="${pk##*/}"   # strip path вҶ’ pwm1
                local val="${pair#*=}"
                case "$varname" in
                    MAXTEMP) FC_MAXTEMP[$pk]="$val" ;;
                    MINTEMP) FC_MINTEMP[$pk]="$val" ;;
                    MINPWM)  FC_MINPWM[$pk]="$val"  ;;
                    MAXPWM)  FC_MAXPWM[$pk]="$val"  ;;
                    FCTEMPS) FC_TEMPS[$pk]="${val##*/}" ;;  # temp6_input
                esac
            done
        esac
    done < "$cfg"
}

start_logging() {
    LOG_FILE="/tmp/qnap-stress-$(date '+%Y%m%d-%H%M%S').csv"
    printf 'timestamp,phase,t1_ec,t6_ec,t7_ec,t8_ec,cpu_pkg,pwm1,pwm7,fan1,fan2,fan3,fan4,fan7,fan8\n' > "$LOG_FILE"
    LOG_ACTIVE=1; PHASE="IDLE"
}

stop_logging() { LOG_ACTIVE=0; }

start_stress() {
    if ! command -v stress-ng &>/dev/null; then
        STRESS_ERROR="stress-ng not found (apt install stress-ng)"; return 1
    fi
    stress-ng --cpu "$(nproc)" --timeout 0 &>/dev/null &
    STRESS_PID=$!; PHASE="LOAD"; STRESS_ERROR=""
}

stop_stress() {
    [[ "$STRESS_PID" -ne 0 ]] && kill "$STRESS_PID" 2>/dev/null && wait "$STRESS_PID" 2>/dev/null
    STRESS_PID=0; PHASE="COOLDOWN"; COOLDOWN_START=$(date '+%s')
}

# analyze_csv <file> <mode>
# mode: "screen" вҖ” overlay in terminal, wait for keypress
#       "stdout" вҖ” print to stdout
analyze_csv() {
    local csvfile="$1" mode="$2"

    # Pass 1: per-phase averages and peaks via awk
    local stats
    stats=$(awk -F',' '
    NR==1 { next }
    {
        phase=$2; t1=$3+0; t6=$4+0; pkg=$7+0; pwm1=$8+0; pwm7=$9+0
        cnt[phase]++
        sum_t1[phase]+=t1; sum_t6[phase]+=t6; sum_pkg[phase]+=pkg
        if (t1   > peak_t1[phase])   peak_t1[phase]=t1
        if (t6   > peak_t6[phase])   peak_t6[phase]=t6
        if (pkg  > peak_pkg[phase])  peak_pkg[phase]=pkg
        if (pwm7 > peak_pwm7[phase]) peak_pwm7[phase]=pwm7
        if (pwm1 > peak_pwm1[phase]) peak_pwm1[phase]=pwm1
        if (phase=="IDLE" && pwm7 > idle_pwm7_max) idle_pwm7_max=pwm7
    }
    END {
        for (p in cnt) {
            avg_t1[p]  = (cnt[p]>0) ? int(sum_t1[p]/cnt[p])  : 0
            avg_t6[p]  = (cnt[p]>0) ? int(sum_t6[p]/cnt[p])  : 0
            avg_pkg[p] = (cnt[p]>0) ? int(sum_pkg[p]/cnt[p]) : 0
        }
        printf "IDLE_T1_AVG=%d\n",    avg_t1["IDLE"]+0
        printf "IDLE_T6_AVG=%d\n",    avg_t6["IDLE"]+0
        printf "IDLE_PKG_AVG=%d\n",   avg_pkg["IDLE"]+0
        printf "LOAD_T1_AVG=%d\n",    avg_t1["LOAD"]+0
        printf "LOAD_T6_AVG=%d\n",    avg_t6["LOAD"]+0
        printf "LOAD_PKG_AVG=%d\n",   avg_pkg["LOAD"]+0
        printf "LOAD_T1_PEAK=%d\n",   peak_t1["LOAD"]+0
        printf "LOAD_T6_PEAK=%d\n",   peak_t6["LOAD"]+0
        printf "LOAD_PKG_PEAK=%d\n",  peak_pkg["LOAD"]+0
        printf "LOAD_PWM7_PEAK=%d\n", peak_pwm7["LOAD"]+0
        printf "LOAD_PWM1_PEAK=%d\n", peak_pwm1["LOAD"]+0
        printf "IDLE_PWM7_BASE=%d\n", idle_pwm7_max+0
        printf "IDLE_CNT=%d\n",       cnt["IDLE"]+0
        printf "LOAD_CNT=%d\n",       cnt["LOAD"]+0
        printf "COOLDOWN_CNT=%d\n",   cnt["COOLDOWN"]+0
    }
    ' "$csvfile")
    eval "$stats"

    # Duration from first/last CSV data rows
    local _first_ts _last_ts duration_str="N/A"
    _first_ts=$(awk -F',' 'NR==2{print $1; exit}' "$csvfile")
    _last_ts=$(awk -F',' 'END{print $1}' "$csvfile")
    if [[ -n "$_first_ts" && -n "$_last_ts" ]]; then
        local _t1 _t2
        _t1=$(date -d "$_first_ts" '+%s' 2>/dev/null || echo 0)
        _t2=$(date -d "$_last_ts"  '+%s' 2>/dev/null || echo 0)
        if [[ "$_t1" -gt 0 && "$_t2" -gt "$_t1" ]]; then
            local _dur=$(( _t2 - _t1 ))
            duration_str="$(( _dur / 60 ))m $(( _dur % 60 ))s"
        fi
    fi

    # Pass 2: fan lag вҖ” seconds from first LOAD row until pwm7 rises >10% above idle baseline
    local idle_pwm7_base_raw="${IDLE_PWM7_BASE:-0}"
    local threshold=$(( idle_pwm7_base_raw + 26 ))   # ~10% of 255
    local load_start_epoch="" rise_epoch="" lag_sec="N/A"

    while IFS=',' read -r ts phase t1 t6 t7 t8 pkg pwm1 pwm7 f1 f2 f3 f4 f7 f8; do
        [[ "$ts" == "timestamp" ]] && continue
        if [[ "$phase" == "LOAD" && -z "$load_start_epoch" ]]; then
            load_start_epoch=$(date -d "$ts" '+%s' 2>/dev/null || echo 0)
        fi
        if [[ "$phase" == "LOAD" && -n "$load_start_epoch" && -z "$rise_epoch" ]]; then
            if [[ "$pwm7" -gt "$threshold" ]]; then
                rise_epoch=$(date -d "$ts" '+%s' 2>/dev/null || echo 0)
            fi
        fi
    done < "$csvfile"

    if [[ -n "$load_start_epoch" && -n "$rise_epoch" && \
          "$load_start_epoch" -gt 0 && "$rise_epoch" -gt 0 ]]; then
        lag_sec=$(( rise_epoch - load_start_epoch ))
    fi

    # Verdict thresholds from parsed fancontrol
    local cpu_maxtemp="${FC_MAXTEMP[pwm7]:-85}"
    local drv_maxtemp="${FC_MAXTEMP[pwm1]:-50}"
    local cpu_margin=$(( cpu_maxtemp - LOAD_T1_PEAK ))
    local drv_margin=$(( drv_maxtemp - LOAD_T6_PEAK ))

    local cpu_verdict drv_verdict lag_verdict pwm_suggest
    # Note: MAXTEMP = temp at which fancontrol ramps fan to 100%, not a hardware limit.
    # Margin = how many degrees below MAXTEMP the peak stayed.
    if   [[ "$cpu_margin" -ge 10 ]]; then
        cpu_verdict="${G}[OK]${N}   CPU peak ${LOAD_T1_PEAK}В°C, margin ${cpu_margin}В°C below MAXTEMP ${cpu_maxtemp}В°C вҖ” fancontrol config OK"
    elif [[ "$cpu_margin" -ge 5  ]]; then
        cpu_verdict="${Y}[WARN]${N} CPU peak ${LOAD_T1_PEAK}В°C, margin only ${cpu_margin}В°C below MAXTEMP ${cpu_maxtemp}В°C вҖ” consider lowering MAXTEMP[pwm7]"
    else
        cpu_verdict="${R}[CRIT]${N} CPU peak ${LOAD_T1_PEAK}В°C = MAXTEMP ${cpu_maxtemp}В°C (fan was at 100%, no headroom) вҖ” lower MAXTEMP[pwm7] in fancontrol"
    fi

    if   [[ "$drv_margin" -ge 10 ]]; then
        drv_verdict="${G}[OK]${N}   Drive peak ${LOAD_T6_PEAK}В°C, margin ${drv_margin}В°C below MAXTEMP ${drv_maxtemp}В°C вҖ” fancontrol config OK"
    elif [[ "$drv_margin" -ge 5  ]]; then
        drv_verdict="${Y}[WARN]${N} Drive peak ${LOAD_T6_PEAK}В°C, margin only ${drv_margin}В°C below MAXTEMP ${drv_maxtemp}В°C вҖ” consider lowering MAXTEMP[pwm1]"
    else
        drv_verdict="${R}[CRIT]${N} Drive peak ${LOAD_T6_PEAK}В°C = MAXTEMP ${drv_maxtemp}В°C (fan at 100%, no headroom) вҖ” lower MAXTEMP[pwm1] in fancontrol"
    fi

    if [[ "$lag_sec" == "N/A" ]]; then
        lag_verdict="${D}[N/A]${N}  Fan lag not measurable (not enough LOAD data)"
    elif [[ "$lag_sec" -le 30 ]]; then
        lag_verdict="${G}[OK]${N}   Fan lag ${lag_sec}s вҖ” fancontrol responds quickly enough"
    else
        lag_verdict="${Y}[WARN]${N} Fan lag ${lag_sec}s (>30s) вҖ” fancontrol slow to react"
    fi

    local minpwm7="${FC_MINPWM[pwm7]:-0}"
    if [[ "$minpwm7" -gt 127 ]]; then
        pwm_suggest="${Y}[SUGGEST]${N} pwm7 MINPWM=${minpwm7} ($(( minpwm7*100/255 ))%) вҖ” consider lowering for quieter idle"
    else
        pwm_suggest="${G}[OK]${N}   pwm7 MINPWM=${minpwm7} ($(( minpwm7*100/255 ))%) вҖ” idle fan speed reasonable"
    fi

    # Render report
    if [[ "$mode" == "screen" ]]; then
        tput cup 0 0
        tput ed
    fi

    local sep='в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ'
    printf "${BOLD}%s${N}\n" "$sep"
    printf " Stress-test Analysis Report\n"
    printf " ${D}Duration: %-10s  IDLE: %d  LOAD: %d  COOLDOWN: %d samples${N}\n" \
        "$duration_str" "${IDLE_CNT:-0}" "${LOAD_CNT:-0}" "${COOLDOWN_CNT:-0}"
    printf "${BOLD}%s${N}\n\n" "$sep"

    printf "${W}Temperature summary:${N}\n"
    printf "  %-22s  idle avg: %3dВ°C  load avg: %3dВ°C  load peak: %3dВ°C\n" \
        "CPU zone (EC t1):" "$IDLE_T1_AVG" "$LOAD_T1_AVG" "$LOAD_T1_PEAK"
    printf "  %-22s  idle avg: %3dВ°C  load avg: %3dВ°C  load peak: %3dВ°C\n" \
        "Drive zone 1 (t6):" "$IDLE_T6_AVG" "$LOAD_T6_AVG" "$LOAD_T6_PEAK"
    printf "  %-22s  idle avg: %3dВ°C  load avg: %3dВ°C  load peak: %3dВ°C\n\n" \
        "CPU pkg (coretemp):" "$IDLE_PKG_AVG" "$LOAD_PKG_AVG" "$LOAD_PKG_PEAK"

    printf "${W}Fan response:${N}\n"
    printf "  PWM7 idle baseline: %3d/255  (%d%%)\n" \
        "$idle_pwm7_base_raw" "$(( idle_pwm7_base_raw * 100 / 255 ))"
    printf "  PWM7 load peak:     %3d/255  (%d%%)\n" \
        "$LOAD_PWM7_PEAK" "$(( LOAD_PWM7_PEAK * 100 / 255 ))"
    printf "  PWM1 load peak:     %3d/255  (%d%%)\n" \
        "$LOAD_PWM1_PEAK" "$(( LOAD_PWM1_PEAK * 100 / 255 ))"
    printf "  Fan lag:            %s s\n\n" "$lag_sec"

    printf "${W}Verdict:${N}\n"
    printf "  %b\n" "$cpu_verdict"
    printf "  %b\n" "$drv_verdict"
    printf "  %b\n" "$lag_verdict"
    printf "  %b\n\n" "$pwm_suggest"

    printf "${BOLD}%s${N}\n" "$sep"

    if [[ "$mode" == "screen" ]]; then
        printf "\n  ${D}Press any key to return...${N}"
        read -r -s -n1
    fi
}

# в”Җв”Җ --analyze entry point (before find_hwmon, which requires the kernel module) в”Җв”Җ
if [[ "$1" == "--analyze" ]]; then
    [[ -z "${2:-}" || ! -f "$2" ]] && { printf 'Usage: qnap-monitor --analyze <file.csv>\n' >&2; exit 1; }
    parse_fancontrol
    analyze_csv "$2" "stdout"
    exit 0
fi

INTERVAL=${1:-2}

# в”Җв”Җ Hardware detection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
HW=$(find_hwmon "qnap_ec")   || { printf 'ERROR: qnap_ec hwmon not found (is qnap-ec module loaded?)\n' >&2; exit 1; }
CT=$(find_hwmon "coretemp")  || { printf 'ERROR: coretemp hwmon not found\n' >&2; exit 1; }

# в”Җв”Җ Detect physical cores from coretemp в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Map "Core N" labels to HT thread lists from thread_siblings_list
for _f in "$CT"/temp*_input; do
    _label=$(cat "${_f/_input/_label}" 2>/dev/null) || continue
    [[ "$_label" =~ ^Core[[:space:]]+([0-9]+)$ ]] || continue
    _core="${BASH_REMATCH[1]}"
    CORE_TEMP[$_core]="$_f"
    _sib="/sys/devices/system/cpu/cpu${_core}/topology/thread_siblings_list"
    if [[ -f "$_sib" ]]; then
        mapfile -t _cpus < <(expand_cpu_list "$(cat "$_sib")")
        CORE_CPUS[$_core]="${_cpus[*]}"
    else
        CORE_CPUS[$_core]="$_core"
    fi
done
IFS=$'\n' read -r -d '' -a CORE_IDS \
    < <(printf '%s\n' "${!CORE_TEMP[@]}" | sort -n && printf '\0')

# в”Җв”Җ CPU info (static, read once at startup) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
_cpu_model=$(awk -F': ' '/^model name/{print $2; exit}' /proc/cpuinfo \
    | sed 's/Intel(R) //; s/Xeon(R) /Xeon /; s/Core(TM) //; s/ CPU / /; s/(R)//g; s/(TM)//g; s/  */ /g; s/ *$//')
_cpu_cores=$(awk -F': ' '/^cpu cores/{print $2; exit}' /proc/cpuinfo)
_cpu_threads=$(awk -F': ' '/^siblings/{print $2; exit}' /proc/cpuinfo)
CPU_INFO="${_cpu_model} В· ${_cpu_cores}C/${_cpu_threads}T"

# в”Җв”Җ Parse fancontrol в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
parse_fancontrol

# в”Җв”Җ Initial CPU stats в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
read_cpu_stats
save_cpu_stats
FIRST_RUN=1

# в”Җв”Җ Terminal в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
tput civis; tput smcup
trap '[[ ${STRESS_PID:-0} -ne 0 ]] && kill "$STRESS_PID" 2>/dev/null; tput rmcup; tput cnorm; exit 0' INT TERM EXIT

# в”Җв”Җ Main loop в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
while true; do

    read_cpu_stats
    tput cup 0 0
    NOW=$(date '+%Y-%m-%d %H:%M:%S')
    COLS=$(tput cols)

    # COOLDOWN вҶ’ IDLE transition: temp recovered or 5-minute timeout
    if [[ "$PHASE" == "COOLDOWN" ]]; then
        _elapsed=$(( $(date '+%s') - COOLDOWN_START ))
        _t1_now=$(read_temp "$HW/temp1_input")
        if [[ "$_t1_now" -le $(( ${FC_MINTEMP[pwm7]:-45} + 5 )) || "$_elapsed" -ge 300 ]]; then
            PHASE="IDLE"
        fi
    fi

    # Header
    printf "${REV}${BOLD}  QNAP TVS-h1288X | Thermal & Fan Monitor | %-*s  ${N}\n" \
        $(( COLS - 47 )) "$NOW"

    # Second header line вҖ” status indicators + key hints
    printf "  "
    [[ "$LOG_ACTIVE" -eq 1 ]] && printf "${R}[LOG в—Ҹ]${N} "
    [[ "$STRESS_PID" -ne 0 ]] && printf "${Y}[STRESS]${N} "
    [[ "$PHASE" != "IDLE"  ]] && printf "${C}[${PHASE}]${N} "
    [[ -n "$STRESS_ERROR"  ]] && printf "${Y}${STRESS_ERROR}${N} "
    stress_hint="s=stress"; [[ "$HAS_STRESS_NG" -eq 0 ]] && stress_hint="s=stress (!)"
    printf "${D}Interval: ${INTERVAL}s  |  q=quit l=log ${stress_hint}  |  ${VERSION}${N}\n\n"

    # Pre-read fan RPMs (needed for CSV; display reuses cat output below)
    fan1=$(cat "$HW/fan1_input" 2>/dev/null || echo 0)
    fan2=$(cat "$HW/fan2_input" 2>/dev/null || echo 0)
    fan3=$(cat "$HW/fan3_input" 2>/dev/null || echo 0)
    fan4=$(cat "$HW/fan4_input" 2>/dev/null || echo 0)
    fan7=$(cat "$HW/fan7_input" 2>/dev/null || echo 0)
    fan8=$(cat "$HW/fan8_input" 2>/dev/null || echo 0)

    # в”Җв”Җ CPU в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    _cpu_hdr="  -- CPU -- [${CPU_INFO}] "
    _cpu_dashes=$(printf '%*s' $(( 69 - ${#_cpu_hdr} )) '' | tr ' ' '-')
    printf "${W}${BOLD}%s%s${N}\n" "$_cpu_hdr" "$_cpu_dashes"

    pkg=$(read_temp "$CT/temp1_input")
    total_pct=$(cpu_pct "cpu")

    printf "  %-10s " "Package:"
    printf "$(temp_color $pkg 75 90)%3d C${N}  " "$pkg"
    bar "$pkg" 100 13
    if [ "$FIRST_RUN" -eq 1 ]; then
        printf "   Total load: ${D}[-- measuring --]${N}\n"
    else
        printf "   Total load: "
        bar "$total_pct" 100 15
        echo ""
    fi

    printf "${D}  %-10s %-19s  %s${N}\n" "" "temp" "load (CPU threads)"

    for core in "${CORE_IDS[@]}"; do
        f="${CORE_TEMP[$core]}"
        t=$(read_temp "$f")
        read -r -a cpu_list <<< "${CORE_CPUS[$core]}"

        printf "  Core %d:  $(temp_color $t 75 90)%3d C${N}  " "$core" "$t"
        bar "$t" 100 13
        printf "  "
        if [ "$FIRST_RUN" -eq 1 ]; then
            for cpu in "${cpu_list[@]}"; do
                printf "${D}cpu%-2d [-- measuring --]  ${N}" "$cpu"
            done
        else
            for cpu in "${cpu_list[@]}"; do
                pct=$(cpu_pct "cpu${cpu}")
                printf "${D}cpu%-2d${N} " "$cpu"
                bar "$pct" 100 10
                printf "  "
            done
        fi
        echo ""
    done
    echo ""

    # в”Җв”Җ EC Chip в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    printf "${W}${BOLD}  -- EC Chip (IT8528) -----------------------------------------------${N}\n"

    t1=$(read_temp "$HW/temp1_input")
    t6=$(read_temp "$HW/temp6_input")
    t7=$(read_temp "$HW/temp7_input")
    t8=$(read_temp "$HW/temp8_input")

    printf "  %-20s $(temp_color $t1 75 90)%3d C${N}  " "CPU zone (EC):"    "$t1"; bar "$t1" 100 22; echo ""
    printf "  %-20s $(temp_color $t6 45 55)%3d C${N}  " "Drive zone 1:"     "$t6"; bar "$t6"  60 22; echo ""
    printf "  %-20s $(temp_color $t7 45 55)%3d C${N}  " "Drive zone 2:"     "$t7"; bar "$t7"  60 22; echo ""
    printf "  %-20s $(temp_color $t8 30 40)%3d C${N}  " "Ambient (intake):" "$t8"; bar "$t8"  45 22; echo ""
    echo ""

    # в”Җв”Җ Fans в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    printf "${W}${BOLD}  -- Fans -----------------------------------------------------------${N}\n"

    pwm1=$(cat "$HW/pwm1" 2>/dev/null || echo 0)
    pwm7=$(cat "$HW/pwm7" 2>/dev/null || echo 0)

    printf "  ${C}Chassis (PWM %3d%%)${N}\n" $(( pwm1 * 100 / 255 ))
    for i in 1 2 3 4; do
        f="$HW/fan${i}_input"; [ -f "$f" ] || continue
        rpm=$(cat "$f")
        printf "  %-20s ${G}%4d RPM${N}  " "  fan${i}:" "$rpm"
        bar "$rpm" 3000 22; echo ""
    done

    printf "  ${C}CPU fan (PWM %3d%%)${N}\n" $(( pwm7 * 100 / 255 ))
    for i in 7 8; do
        f="$HW/fan${i}_input"; [ -f "$f" ] || continue
        rpm=$(cat "$f")
        printf "  %-20s ${G}%4d RPM${N}  " "  fan${i}:" "$rpm"
        bar "$rpm" 3000 22; echo ""
    done
    echo ""

    # в”Җв”Җ Fan curves в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    printf "${W}${BOLD}  -- Fan curves (fancontrol) -----------------------------------------${N}\n"
    draw_pwm_curve "Chassis (pwm1):" \
        "${FC_MINTEMP[pwm1]:-30}" "${FC_MAXTEMP[pwm1]:-50}" \
        "${FC_MINPWM[pwm1]:-80}"  "${FC_MAXPWM[pwm1]:-255}" \
        "$t6" "$pwm1"
    draw_pwm_curve "CPU fan (pwm7):" \
        "${FC_MINTEMP[pwm7]:-45}" "${FC_MAXTEMP[pwm7]:-85}" \
        "${FC_MINPWM[pwm7]:-60}"  "${FC_MAXPWM[pwm7]:-255}" \
        "$t1" "$pwm7"
    echo ""

    # в”Җв”Җ CSV append в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    if [[ "$LOG_ACTIVE" -eq 1 ]]; then
        printf '%s,%s,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d\n' \
            "$(date '+%Y-%m-%d %H:%M:%S')" "$PHASE" \
            "$t1" "$t6" "$t7" "$t8" "$pkg" "$pwm1" "$pwm7" \
            "$fan1" "$fan2" "$fan3" "$fan4" "$fan7" "$fan8" \
            >> "$LOG_FILE"
    fi

    # в”Җв”Җ Drives (top 5 hottest) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    printf "${W}${BOLD}  -- Drives (top 5 hottest) -----------------------------------------${N}\n"

    temps=()
    for h in /sys/class/hwmon/hwmon*/; do
        [ "$(cat "$h/name" 2>/dev/null)" = "drivetemp" ] || continue
        t=$(read_temp "$h/temp1_input")
        dev=$(ls "$h/device/block/" 2>/dev/null | head -1 || echo "?")
        temps+=("$t $dev")
    done

    count=0
    while IFS= read -r line; do
        [ "$count" -ge 5 ] && break
        t=$(awk '{print $1}' <<< "$line")
        dev=$(awk '{print $2}' <<< "$line")
        printf "  %-20s $(temp_color $t 40 50)%3d C${N}  " "$dev:" "$t"
        bar "$t" 60 22; echo ""
        (( count++ ))
    done < <(printf '%s\n' "${temps[@]}" | sort -rn)
    echo ""

    # в”Җв”Җ Status в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    fc_status=$(systemctl is-active fancontrol 2>/dev/null)
    if [ "$fc_status" = "active" ]; then
        printf "  ${G}[OK] fancontrol active${N}"
    else
        printf "  ${R}[!!] fancontrol INACTIVE${N}"
    fi
    if [[ "$LOG_ACTIVE" -eq 1 ]]; then
        printf "   ${D}Logging вҶ’ %s${N}" "$LOG_FILE"
    fi
    printf "\n  ${D}q=quit  l=log  s=stress  |  Ctrl+C = interrupt${N}\n"

    # Save stats and wait
    save_cpu_stats
    FIRST_RUN=0
    tput ed

    read -r -s -n1 -t "$INTERVAL" key 2>/dev/null
    case "$key" in
        q|Q) break ;;
        l|L)
            if [[ "$LOG_ACTIVE" -eq 0 ]]; then
                start_logging
            else
                stop_logging
                analyze_csv "$LOG_FILE" "screen"
            fi ;;
        s|S)
            if [[ "$STRESS_PID" -eq 0 ]]; then start_stress
            else stop_stress; fi ;;
    esac

done
